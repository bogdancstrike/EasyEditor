root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true
max_line_length = 100

[*.{kt,kts}]
indent_size = 4
ij_kotlin_imports_layout = *
ktlint_standard_no-wildcard-imports = enabled

[*.{yml,yaml,json}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab

[*.{cpp,h,hpp,mm,m}]
indent_size = 4

[*.gradle]
indent_size = 4
