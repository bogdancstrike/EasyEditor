* text=auto eol=lf

# Binary
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.heic binary
*.ico binary
*.aar binary
*.jar binary
*.keystore binary
*.jks binary

# Git LFS — sample media and large LUT packs
test_assets/samples/*.mp4 filter=lfs diff=lfs merge=lfs -text
test_assets/samples/*.mov filter=lfs diff=lfs merge=lfs -text
test_assets/samples/*.mkv filter=lfs diff=lfs merge=lfs -text
test_assets/samples/*.dng filter=lfs diff=lfs merge=lfs -text
test_assets/golden/*.png filter=lfs diff=lfs merge=lfs -text

# Generated / shouldn't appear in diffs
*.lock linguist-generated=true
gradle/wrapper/gradle-wrapper.jar binary
